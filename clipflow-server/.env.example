# TikTok Clip Machine — Environment Variables

# Anthropic (Claude - for moment detection + viral titles)
ANTHROPIC_API_KEY=

# ElevenLabs (Spanish dubbing)
ELEVENLABS_API_KEY=

# OpenAI Whisper (transcription)
OPENAI_API_KEY=

# HeyGen (video translation + lip sync)
HEYGEN_API_KEY=

# Server
PORT=4000

# yt-dlp cookies file path (export from browser using cookies.txt extension)
YTDLP_COOKIES=/path/to/cookies.txt

# Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
APP_URL=http://YOUR_SERVER_IP:4000
STRIPE_STARTER_PRICE=
STRIPE_PRO_PRICE=
STRIPE_UNLIMITED_PRICE=
PUBLIC_URL=https://your-domain.com
