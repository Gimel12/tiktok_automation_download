# ClipFlow Watcher — Environment Variables
# Copy this file to .env and fill in your values.
# Each channel gets its own folder with its own .env file.

# YouTube channel to watch (Shorts tab)
CHANNEL_URL=https://www.youtube.com/@CHANNEL_HANDLE/shorts

# ClipFlow server (always local)
CLIPFLOW_API=http://localhost:4000

# Your public domain for Cloudflare tunnel (used for video URLs)
PUBLIC_DOMAIN=https://clips.yourdomain.com

# Telegram bot — for notifications and video delivery
TG_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TG_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# Path to yt-dlp cookies file (needed for age-restricted videos)
# Export from Chrome using the "Get cookies.txt LOCALLY" extension
COOKIES_FILE=/path/to/cookies.txt

# Postiz — schedules video to TikTok
POSTIZ_API_KEY=YOUR_POSTIZ_API_KEY
POSTIZ_TIKTOK_ID=YOUR_POSTIZ_TIKTOK_INTEGRATION_ID
