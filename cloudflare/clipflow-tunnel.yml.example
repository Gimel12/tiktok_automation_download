# Cloudflare Tunnel config for ClipFlow
# Place at: ~/.cloudflared/clipflow-tunnel.yml
#
# Setup steps:
#   1. brew install cloudflare/cloudflare/cloudflared
#   2. cloudflared tunnel login
#   3. cloudflared tunnel create clipflow
#   4. Copy the tunnel ID shown and paste below
#   5. Update hostname to your custom domain
#   6. Add a CNAME record in Cloudflare DNS:
#      clips.yourdomain.com → YOUR_TUNNEL_ID.cfargotunnel.com

tunnel: YOUR_TUNNEL_ID
credentials-file: /Users/YOUR_USERNAME/.cloudflared/YOUR_TUNNEL_ID.json

ingress:
  - hostname: clips.yourdomain.com
    service: http://localhost:4000
  - service: http_status:404
